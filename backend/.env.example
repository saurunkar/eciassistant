# ── GCP Core ─────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-south1

# ── Vertex AI ────────────────────────────────────────────────────────────────
VERTEX_AI_LOCATION=asia-south1
VERTEX_AI_MODEL=gemini-1.5-pro
# Leave blank to run without Vertex AI Search (built-in fallback knowledge base)
VERTEX_AI_SEARCH_ENGINE_ID=

# ── Firestore ────────────────────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)

# ── Cloud Storage ────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=electguide-eci-docs

# ── Session config ───────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24
MAX_MESSAGES_PER_SESSION=20

# ── Security / CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://electguide-india.web.app,http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Local dev only: leave blank in Cloud Run (uses workload identity) ─────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
